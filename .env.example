# Copy this file to .env and fill in the values before running docker compose.

# DHIS2 API token — used when config.yml contains: d2_token: ${DHIS2_API_TOKEN}
DHIS2_API_TOKEN=d2p_your_token_here

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me
