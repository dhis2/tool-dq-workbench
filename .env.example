# Copy this file to .env and fill in the values before running docker compose.

# DHIS2 instance URL (no trailing slash)
DHIS2_BASE_URL=https://your-dhis2-instance.org

# DHIS2 personal access token
DHIS2_API_TOKEN=d2p_your_token_here

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Optional: if not set, a random key is used and sessions reset on restart.
FLASK_SECRET_KEY=change_me
